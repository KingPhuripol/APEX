# APEX Clinical AI - Environment Configuration

# Primary Vision API (Used by Analyst Agent)
# Recommended: OpenAI GPT-4o for structured JSON outputs and vision
OPENAI_API_KEY=your_openai_api_key_here
PRIMARY_VISION_API=gpt-5.4-mini

# Critique & Formatter API (Used for Thai localization and double-checking)
# Recommended: SCB 10X Typhoon 1.5x/2.0
# If using Typhoon via LiteLLM custom endpoint, set the API base and key
TYPHOON_API_KEY=your_typhoon_api_key_here
CRITIQUE_VISION_API=openai/typhoon-v2.5-30b-a3b-instruct
LITELLM_CUSTOM_API_BASE=https://api.opentyphoon.ai/v1

# Fallback & Quality Gate API (Used for ultra-fast validation)
# Recommended: Groq Llama 3 Vision
GROQ_API_KEY=your_groq_api_key_here
FALLBACK_VISION_API=groq/openai/gpt-oss-20b

# LiteLLM Master Key (Optional, if routing through a proxy)
LITELLM_KEY=

# Flask Settings
FLASK_DEBUG=1
PORT=5001
