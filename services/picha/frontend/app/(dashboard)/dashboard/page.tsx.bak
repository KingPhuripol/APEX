"use client";
// Main dashboard — stats, slide upload, live agent pipeline, audit log

import { useState, useEffect, useRef, useCallback } from "react";
import { api } from "@/lib/api";
import {
  Upload,
  RefreshCw,
  CheckCircle,
  XCircle,
  ChevronDown,
  ChevronUp,
  Loader2,
  Microscope,
  ScanSearch,
  Bug,
  BarChart3,
  Map,
  Hospital,
  Timer,
  FileText,
  Cpu,
  Zap,
  Printer,
  AlertCircle,
} from "lucide-react";

// ── Types ──────────────────────────────────────────────────────────────────

interface AgentEvent {
  agent: string;
  type: string;
  message: string;
  is_final: boolean;
}

interface AuditLog {
  id: string;
  created_at: string;
  user_name: string;
  action: string;
  patient_hn: string | null;
  confidence: number | null;
  status: string;
}

// ── Agent display metadata ─────────────────────────────────────────────────

const AGENT_META: Record<
  string,
  { icon: React.ElementType; color: string; label: string }
> = {
  MLPrescreen: {
    icon: Microscope,
    color: "text-purple-400",
    label: "ML Pre-screen",
  },
  SlideQCAgent: { icon: ScanSearch, color: "text-blue-400", label: "Slide QC" },
  ParasitologistAgent: {
    icon: Bug,
    color: "text-emerald-400",
    label: "Parasitologist",
  },
  GradingAgent: {
    icon: BarChart3,
    color: "text-yellow-400",
    label: "WHO Grading",
  },
  SpatialAgent: {
    icon: Map,
    color: "text-orange-400",
    label: "Spatial Analysis",
  },
  OncologistAgent: {
    icon: Hospital,
    color: "text-red-400",
    label: "Oncologist",
  },
  TimeMachineAgent: {
    icon: Timer,
    color: "text-pink-400",
    label: "Time Machine",
  },
  ReportAgent: { icon: FileText, color: "text-cyan-400", label: "Report" },
  PICHAOrchestrator: {
    icon: Cpu,
    color: "text-gray-300",
    label: "Orchestrator",
  },
  System: { icon: Zap, color: "text-gray-400", label: "System" },
};

// ── Sub-components ─────────────────────────────────────────────────────────

function StatCard({
  label,
  value,
  sub,
  icon: Icon,
  accent,
}: {
  label: string;
  value: string | number;
  sub?: string;
  icon: React.ElementType;
  accent: string;
}) {
  return (
    <div className="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm flex items-start gap-4">
      <div
        className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${accent}`}
      >
        <Icon className="w-5 h-5" />
      </div>
      <div className="min-w-0">
        <p className="text-slate-400 text-[11px] font-bold uppercase tracking-widest mb-1">
          {label}
        </p>
        <p className="text-[#0a1628] text-2xl font-extrabold leading-none truncate">
          {value}
        </p>
        {sub && <p className="text-slate-400 text-xs mt-1">{sub}</p>}
      </div>
    </div>
  );
}

// Step order for pipeline display
const AGENT_STEP_ORDER: Record<string, number> = {
  MLPrescreen: 0,
  SlideQCAgent: 1,
  ParasitologistAgent: 2,
  GradingAgent: 3,
  SpatialAgent: 4,
  OncologistAgent: 5,
  TimeMachineAgent: 6,
  ReportAgent: 7,
};

// Returns true for events that are meaningful to a clinician
function isDisplayableEvent(event: AgentEvent): boolean {
  const msg = event.message;
  if (msg.startsWith("[")) return false;
  if (event.agent === "user" || event.agent === "User") return false;
  if (
    event.agent === "PICHAOrchestrator" &&
    /^[A-Z][a-zA-Z]+Agent:/.test(msg)
  )
    return false;
  if (event.type === "thinking") return false;
  return true;
}

// ── Explainable AI Step Card ───────────────────────────────────────────────

function AgentStepCard({
  event,
  stepNumber,
}: {
  event: AgentEvent;
  stepNumber: number;
}) {
  const [expanded, setExpanded] = useState(false);
  const meta = AGENT_META[event.agent] ?? {
    icon: Zap,
    color: "text-slate-500",
    label: event.agent,
  };
  const AgentIcon = meta.icon;

  // Special rendering for the final ReportAgent conclusion
  if (event.is_final) {
    return (
      <div className="rounded-xl border-2 border-[#1d4ed8]/25 bg-blue-50/60 px-4 py-3 flex items-center gap-3">
        <span className="w-7 h-7 rounded-full bg-[#1d4ed8] text-white text-xs font-bold flex items-center justify-center shrink-0">
          ✓
        </span>
        <div className="w-7 h-7 rounded-lg bg-[#1d4ed8]/10 flex items-center justify-center shrink-0">
          <AgentIcon className="w-4 h-4 text-[#1d4ed8]" />
        </div>
        <div className="flex-1">
          <p className="text-[#0a1628] text-sm font-semibold">{meta.label}</p>
          <p className="text-slate-500 text-xs">Report generated — see below</p>
        </div>
        <span className="text-[10px] font-bold bg-[#1d4ed8] text-white px-2.5 py-1 rounded-full shrink-0">
          COMPLETE
        </span>
      </div>
    );
  }

  // Parse agent JSON output
  let parsed: Record<string, unknown> | null = null;
  let narrative = event.message;
  let confidence: number | null = null;
  let keyFindings: string[] = [];

  try {
    parsed = JSON.parse(event.message);
    if (parsed) {
      if (typeof parsed.narrative === "string") narrative = parsed.narrative;
      else if (typeof parsed.summary === "string") narrative = parsed.summary;
      else if (typeof parsed.recommendation === "string")
        narrative = parsed.recommendation;
      if (typeof parsed.confidence === "number") confidence = parsed.confidence;
      if (Array.isArray(parsed.findings))
        keyFindings = (parsed.findings as string[]).slice(0, 3);
    }
  } catch {
    // Not JSON — show raw text as narrative
  }

  const confColor =
    confidence === null
      ? ""
      : confidence >= 0.7
        ? "text-emerald-700"
        : confidence >= 0.4
          ? "text-yellow-700"
          : "text-red-600";
  const confBar =
    confidence === null
      ? ""
      : confidence >= 0.7
        ? "bg-emerald-500"
        : confidence >= 0.4
          ? "bg-yellow-500"
          : "bg-red-400";

  return (
    <div className="rounded-xl border border-slate-100 bg-white shadow-sm overflow-hidden">
      {/* Header row */}
      <div className="px-4 py-2.5 flex items-center gap-2.5 border-b border-slate-50 bg-slate-50/40">
        <span className="w-6 h-6 rounded-full bg-[#1d4ed8] text-white text-[10px] font-extrabold flex items-center justify-center shrink-0">
          {stepNumber}
        </span>
        <div className="w-6 h-6 rounded-md bg-slate-100 flex items-center justify-center shrink-0">
          <AgentIcon className={`w-3.5 h-3.5 ${meta.color}`} />
        </div>
        <div className="flex-1 min-w-0">
          <p className="text-[#0a1628] text-xs font-bold leading-none">
            {meta.label}
          </p>
          <p className="text-slate-400 text-[10px] mt-0.5">{event.agent}</p>
        </div>
        {confidence !== null && (
          <div className="flex items-center gap-1.5 shrink-0">
            <div className="w-14 h-1 rounded-full bg-slate-200 overflow-hidden">
              <div
                className={`h-full rounded-full ${confBar}`}
                style={{ width: `${Math.round(confidence * 100)}%` }}
              />
            </div>
            <span className={`text-[10px] font-bold ${confColor}`}>
              {Math.round(confidence * 100)}%
            </span>
          </div>
        )}
      </div>

      {/* Narrative body */}
      <div className="px-4 py-3">
        <p className="text-slate-700 text-xs leading-relaxed">{narrative}</p>

        {keyFindings.length > 0 && (
          <ul className="mt-2 space-y-1">
            {keyFindings.map((f, i) => (
              <li
                key={i}
                className="flex items-start gap-1.5 text-[11px] text-slate-600"
              >
                <span className="text-[#1d4ed8] font-bold mt-px shrink-0">
                  ›
                </span>
                <span>{String(f)}</span>
              </li>
            ))}
          </ul>
        )}

        {parsed && (
          <button
            onClick={() => setExpanded((v) => !v)}
            className="mt-2 flex items-center gap-1 text-[10px] text-slate-400 hover:text-[#1d4ed8] transition-colors"
          >
            {expanded ? (
              <ChevronUp className="w-3 h-3" />
            ) : (
              <ChevronDown className="w-3 h-3" />
            )}
            {expanded ? "Hide" : "Show"} technical data
          </button>
        )}
        {expanded && parsed && (
          <pre className="mt-2 text-[10px] text-slate-500 bg-slate-50 rounded-lg p-3 overflow-x-auto whitespace-pre-wrap border border-slate-100 leading-relaxed">
            {JSON.stringify(parsed, null, 2)}
          </pre>
        )}
      </div>
    </div>
  );
}

// ── Medical Report Card with PDF export ───────────────────────────────────

function MedicalReportCard({
  report,
  patientHn,
  fileName,
}: {
  report: Record<string, unknown>;
  patientHn: string;
  fileName: string;
}) {
  const confidence =
    typeof report.overall_confidence === "number"
      ? report.overall_confidence
      : null;
  const recs = Array.isArray(report.recommendations)
    ? (report.recommendations as string[])
    : [];
  const ovPositive =
    report.ov_infection === true || report.ov_infection === "true";
  const confColor =
    confidence === null
      ? "text-slate-500"
      : confidence >= 0.7
        ? "text-emerald-700"
        : confidence >= 0.4
          ? "text-yellow-700"
          : "text-red-600";
  const confBar =
    confidence === null
      ? "bg-slate-300"
      : confidence >= 0.7
        ? "bg-emerald-500"
        : confidence >= 0.4
          ? "bg-yellow-500"
          : "bg-red-400";

  const exportPDF = () => {
    const dateStr = new Date().toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    });
    const confPct =
      confidence !== null ? `${Math.round(confidence * 100)}%` : "—";
    const recsHtml = recs
      .map((r, i) => `<li><span class="num">${i + 1}.</span>${String(r)}</li>`)
      .join("");

    const html = `<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><title>PICHA AI Pathology Report</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:Arial,Helvetica,sans-serif;max-width:780px;margin:0 auto;padding:40px;color:#111827;font-size:13px}
  .header{display:flex;justify-content:space-between;align-items:flex-start;padding-bottom:18px;border-bottom:3px solid #1d4ed8;margin-bottom:24px}
  .header h1{font-size:22px;color:#1d4ed8;font-weight:800;letter-spacing:-0.5px}
  .header .sub{font-size:11px;color:#6b7280;margin-top:3px}
  .meta{text-align:right;font-size:11px;color:#6b7280;line-height:2}
  .meta strong{color:#111827}
  .summary{background:#eff6ff;border-left:4px solid #1d4ed8;padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:20px;font-size:13px;color:#1e3a5f;line-height:1.7}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
  .card{border:1px solid #e5e7eb;border-radius:8px;padding:14px}
  .card-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#9ca3af;margin-bottom:6px}
  .card-value{font-size:15px;font-weight:700;color:#111827}
  .badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:700}
  .badge-pos{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5}
  .badge-neg{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7}
  .badge-ai{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
  .recs{border:1px solid #e5e7eb;border-radius:8px;padding:14px;margin-bottom:16px}
  .recs ul{list-style:none;margin-top:8px}
  .recs li{display:flex;gap:8px;padding:5px 0;border-bottom:1px solid #f3f4f6;font-size:13px;color:#374151}
  .recs li:last-child{border-bottom:none}
  .recs .num{color:#1d4ed8;font-weight:700;min-width:16px}
  .conf-row{display:flex;align-items:center;gap:12px;margin-top:4px}
  .conf-bar-bg{flex:1;height:6px;border-radius:9999px;background:#e5e7eb;overflow:hidden}
  .conf-bar{height:100%;border-radius:9999px;background:#10b981;width:${confPct}}
  .conf-pct{font-size:16px;font-weight:800;color:#10b981}
  .footer{margin-top:32px;padding-top:14px;border-top:1px solid #e5e7eb;font-size:10px;color:#9ca3af;text-align:center;line-height:2}
  @media print{body{padding:20px}button{display:none}}
</style>
</head>
<body>
<div class="header">
  <div>
    <h1>PICHA AI Pathology Report</h1>
    <div class="sub">AI-Assisted Cholangiocarcinoma (CCA) Analysis</div>
  </div>
  <div class="meta">
    Patient HN: <strong>${patientHn || "Not specified"}</strong><br/>
    File: ${fileName}<br/>
    Date: ${dateStr}
  </div>
</div>
${report.summary ? `<div class="summary">${String(report.summary)}</div>` : ""}
<div class="grid2">
  <div class="card">
    <div class="card-label">Primary Diagnosis</div>
    <div class="card-value">${String(report.diagnosis ?? "—")}</div>
  </div>
  <div class="card">
    <div class="card-label">WHO Grade</div>
    <div class="card-value">${String(report.grade ?? "—")}</div>
  </div>
</div>
<div class="grid2">
  <div class="card">
    <div class="card-label">AJCC Stage (8th Edition)</div>
    <div class="card-value">${String(report.stage ?? "—")}</div>
  </div>
  <div class="card">
    <div class="card-label">OV Infection (Opisthorchis viverrini)</div>
    <div class="card-value"><span class="badge ${ovPositive ? "badge-pos" : "badge-neg"}">${ovPositive ? "Positive" : "Negative"}</span></div>
  </div>
</div>
${recs.length > 0 ? `<div class="recs"><div class="card-label">Clinical Recommendations</div><ul>${recsHtml}</ul></div>` : ""}
<div class="card">
  <div class="card-label">Diagnostic Confidence <span class="badge badge-ai" style="margin-left:6px">AI-Assisted</span></div>
  <div class="conf-row"><div class="conf-bar-bg"><div class="conf-bar"></div></div><span class="conf-pct">${confPct}</span></div>
</div>
<div class="footer">
  Generated by PICHA AI v1.0 &nbsp;·&nbsp; ${dateStr}<br/>
  <strong>For clinical decision support only.</strong> Final diagnosis must be confirmed by a licensed pathologist.<br/>
  Cholangiocarcinoma Research Unit · Faculty of Medicine, Khon Kaen University
</div>
</body></html>`;

    const w = window.open("", "_blank", "width=840,height=980");
    if (!w) return;
    w.document.write(html);
    w.document.close();
    setTimeout(() => w.print(), 500);
  };

  return (
    <div className="mt-4 pt-4 border-t border-slate-100 shrink-0">
      <div className="flex items-center justify-between mb-3">
        <h3 className="text-[#0a1628] text-xs font-bold flex items-center gap-1.5 uppercase tracking-widest">
          <FileText className="w-3.5 h-3.5 text-[#1d4ed8]" />
          Pathology Report
        </h3>
        <button
          onClick={exportPDF}
          className="flex items-center gap-1.5 text-[11px] font-semibold text-[#1d4ed8] bg-blue-50 hover:bg-blue-100 px-2.5 py-1.5 rounded-lg transition-colors border border-blue-100"
        >
          <Printer className="w-3 h-3" />
          Print / PDF
        </button>
      </div>

      <div className="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
        {/* Clinical summary */}
        {!!report.summary && (
          <div className="px-4 py-3 bg-blue-50/50 border-b border-slate-100">
            <p className="text-[10px] font-bold uppercase tracking-widest text-[#1d4ed8] mb-1">
              Clinical Summary
            </p>
            <p className="text-slate-700 text-xs leading-relaxed">
              {String(report.summary)}
            </p>
          </div>
        )}

        {/* 2-col grid */}
        <div className="grid grid-cols-2 divide-x divide-y divide-slate-100">
          <div className="px-4 py-3">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">
              Diagnosis
            </p>
            <p className="text-[#0a1628] text-xs font-semibold leading-snug">
              {String(report.diagnosis ?? "—")}
            </p>
          </div>
          <div className="px-4 py-3">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">
              WHO Grade
            </p>
            <p className="text-[#0a1628] text-xs font-semibold">
              {String(report.grade ?? "—")}
            </p>
          </div>
          <div className="px-4 py-3">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">
              AJCC Stage
            </p>
            <p className="text-[#0a1628] text-xs font-semibold">
              {String(report.stage ?? "—")}
            </p>
          </div>
          <div className="px-4 py-3">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">
              OV Infection
            </p>
            <span
              className={`inline-block text-[10px] font-bold px-2 py-0.5 rounded-full border ${
                ovPositive
                  ? "bg-red-50 text-red-700 border-red-100"
                  : "bg-emerald-50 text-emerald-700 border-emerald-100"
              }`}
            >
              {ovPositive ? "Positive" : "Negative"}
            </span>
          </div>
        </div>

        {/* Recommendations */}
        {recs.length > 0 ? (
          <div className="px-4 py-3 border-t border-slate-100">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2">
              Clinical Recommendations
            </p>
            <ol className="space-y-1.5">
              {recs.map((r, i) => (
                <li key={i} className="flex items-start gap-2 text-xs">
                  <span className="text-[#1d4ed8] font-extrabold shrink-0 leading-relaxed">
                    {i + 1}.
                  </span>
                  <span className="text-slate-700 leading-relaxed">
                    {String(r)}
                  </span>
                </li>
              ))}
            </ol>
          </div>
        ) : null}

        {/* Confidence bar */}
        {confidence !== null && (
          <div className="px-4 py-3 border-t border-slate-100 bg-slate-50/40 flex items-center gap-3">
            <p className="text-[10px] font-bold uppercase tracking-widest text-slate-400 shrink-0">
              AI Confidence
            </p>
            <div className="flex-1 h-1.5 rounded-full bg-slate-200 overflow-hidden">
              <div
                className={`h-full rounded-full ${confBar} transition-all duration-700`}
                style={{ width: `${Math.round(confidence * 100)}%` }}
              />
            </div>
            <span className={`text-xs font-bold ${confColor} shrink-0`}>
              {Math.round(confidence * 100)}%
            </span>
          </div>
        )}
      </div>

      <p className="mt-2 text-[10px] text-slate-400 text-center leading-relaxed">
        AI-assisted analysis · For clinical decision support only ·{" "}
        <span className="font-semibold">
          Confirm with a licensed pathologist
        </span>
      </p>
    </div>
  );
}

// ── Main Page ──────────────────────────────────────────────────────────────

export default function DashboardPage() {
  // Audit log state
  const [logs, setLogs] = useState<AuditLog[]>([]);
  const [logsLoading, setLogsLoading] = useState(false);

  // Upload form state
  const [file, setFile] = useState<File | null>(null);
  const [preview, setPreview] = useState<string>("");
  const [patientHn, setPatientHn] = useState("");
  const [clinical, setClinical] = useState("");
  const [dragging, setDragging] = useState(false);

  // Analysis state
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [events, setEvents] = useState<AgentEvent[]>([]);
  const [finalReport, setFinalReport] = useState<Record<
    string,
    unknown
  > | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [done, setDone] = useState(false);

  const eventsEndRef = useRef<HTMLDivElement>(null);
  const readerRef = useRef<ReadableStreamDefaultReader<Uint8Array> | null>(
    null,
  );
  const currentFileRef = useRef<File | null>(null);
  const currentHnRef = useRef<string>("");

  // ── Load audit logs ───────────────────────────────────────────────────

  const loadLogs = useCallback(async () => {
    setLogsLoading(true);
    try {
      const res = await api.get("/api/audit?limit=50");
      if (res.ok) {
        const data = await res.json();
        setLogs(data.logs ?? []);
      }
    } catch {}
    setLogsLoading(false);
  }, []);

  useEffect(() => {
    loadLogs();
  }, [loadLogs]);

  // Auto-scroll agent events
  useEffect(() => {
    eventsEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [events]);

  // ── Computed stats ────────────────────────────────────────────────────

  const todayStr = new Date().toDateString();
  const todayCount = logs.filter(
    (l) => new Date(l.created_at).toDateString() === todayStr,
  ).length;
  const totalConfs = logs.filter(
    (l) => l.confidence && Number(l.confidence) > 0,
  );
  const avgConf =
    totalConfs.length > 0
      ? (
          totalConfs.reduce((s, l) => s + Number(l.confidence), 0) /
          totalConfs.length
        ).toFixed(1)
      : null;

  // ── File handling ─────────────────────────────────────────────────────

  const handleFile = (f: File) => {
    if (!f.type.startsWith("image/")) return;
    setFile(f);
    currentFileRef.current = f;
    const r = new FileReader();
    r.onload = () => setPreview(r.result as string);
    r.readAsDataURL(f);
  };

  // ── Submit / SSE ──────────────────────────────────────────────────────

  const cancelStream = useCallback(() => {
    readerRef.current?.cancel().catch(() => {});
    readerRef.current = null;
  }, []);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!file || isAnalyzing) return;

    cancelStream();
    setIsAnalyzing(true);
    setDone(false);
    setEvents([]);
    setFinalReport(null);
    setError(null);
    currentHnRef.current = patientHn;

    // Convert file to base64 (with data URL prefix — ai-service handles both)
    const base64 = await new Promise<string>((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(r.result as string);
      r.onerror = reject;
      r.readAsDataURL(file);
    });

    const payload = {
      slide_description: clinical.trim() || "Pathology slide for CCA analysis",
      clinical_context: clinical.trim(),
      image_base64: base64,
      patient_region: "Southeast Asia",
    };

    // Fire-and-forget to backend for persistent storage
    api
      .post("/api/analysis", {
        imageBase64: base64,
        patientId: patientHn || undefined,
        clinicalHistory: clinical || undefined,
      })
      .catch(() => {});

    // SSE stream for live agent view
    let res: Response;
    try {
      res = await api.stream(payload);
    } catch {
      setError(
        "Cannot connect to AI service. Make sure all services are running.",
      );
      setIsAnalyzing(false);
      return;
    }

    if (!res.ok || !res.body) {
      setError(
        `AI service returned ${res.status}. Check that ai-service is healthy.`,
      );
      setIsAnalyzing(false);
      return;
    }

    const reader = res.body.getReader();
    readerRef.current = reader;
    const decoder = new TextDecoder();
    let buf = "";
    let reportExtracted: Record<string, unknown> | null = null;

    try {
      outer: while (true) {
        const { done: streamDone, value } = await reader.read();
        if (streamDone) break;
        buf += decoder.decode(value, { stream: true });
        const lines = buf.split("\n");
        buf = lines.pop() ?? "";
        for (const line of lines) {
          if (!line.startsWith("data: ")) continue;
          const raw = line.slice(6).trim();
          if (raw === "[DONE]") {
            break outer;
          }
          try {
            const ev: AgentEvent = JSON.parse(raw);
            setEvents((prev) => [...prev, ev]);
            if (ev.is_final) {
              const msg = ev.message;
              const jsonStr = msg.includes("FINAL_REPORT:")
                ? msg.split("FINAL_REPORT:")[1].trim()
                : msg;
              try {
                reportExtracted = JSON.parse(jsonStr);
                setFinalReport(reportExtracted);
              } catch {
                reportExtracted = { report_text: jsonStr };
                setFinalReport(reportExtracted);
              }
            }
          } catch {}
        }
      }
    } catch (ex) {
      if ((ex as Error).name !== "AbortError") {
        setError("Stream interrupted. Partial results may be available.");
      }
    }

    setDone(true);
    setIsAnalyzing(false);

    // Write audit entry
    await api
      .post("/api/audit", {
        action: `PICHA analysis — ${file.name}`,
        patientHn: patientHn || null,
        result: reportExtracted
          ? JSON.stringify(reportExtracted).slice(0, 500)
          : null,
        confidence:
          reportExtracted && typeof reportExtracted.overall_confidence === "number"
            ? reportExtracted.overall_confidence
            : 0,
        status: "ok",
      })
      .catch(() => {});
    loadLogs();
  };

  // ── Render ────────────────────────────────────────────────────────────

  return (
    <div className="py-8 px-6 space-y-6 max-w-7xl mx-auto">
      {/* Page header */}
      <div className="flex items-start justify-between">
        <div>
          <h1 className="text-2xl font-extrabold text-[#0a1628] tracking-tight">
            Dashboard
          </h1>
          <p className="text-slate-400 text-sm mt-0.5">
            PICHA AI — Cholangiocarcinoma Pathology Platform
          </p>
        </div>
        <span className="text-[11px] font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full flex items-center gap-1.5">
          <span className="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" />
          System Online
        </span>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <StatCard
          label="Today's Analyses"
          value={todayCount}
          sub={`${logs.length} total all time`}
          icon={BarChart3}
          accent="bg-blue-50 text-[#1d4ed8]"
        />
        <StatCard
          label="Avg Confidence"
          value={avgConf ? `${avgConf}%` : "—"}
          sub="from audit log"
          icon={CheckCircle}
          accent="bg-emerald-50 text-emerald-600"
        />
        <StatCard
          label="ML Model"
          value="ConvNeXt"
          sub="Val Acc 77.51% · 9 classes"
          icon={Cpu}
          accent="bg-purple-50 text-purple-600"
        />
        <StatCard
          label="AI Agents"
          value="7 Specialists"
          sub="llama-4-scout + llama-3.3-70b"
          icon={Zap}
          accent="bg-amber-50 text-amber-600"
        />
      </div>

      {/* Analysis Panel */}
      <div className="grid grid-cols-1 xl:grid-cols-5 gap-5">
        {/* ── Upload Form ── */}
        <div className="xl:col-span-2 bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
          <div className="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
              <h2 className="text-[#0a1628] font-bold text-base">
                Quick Analysis
              </h2>
              <p className="text-slate-400 text-xs mt-0.5">
                Upload slide & run instantly
              </p>
            </div>
            <div className="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
              <Upload className="w-4 h-4 text-[#1d4ed8]" />
            </div>
          </div>

          <form onSubmit={handleSubmit} className="p-6 space-y-4">
            {/* Drop zone */}
            <div
              onDragOver={(e) => {
                e.preventDefault();
                setDragging(true);
              }}
              onDragLeave={() => setDragging(false)}
              onDrop={(e) => {
                e.preventDefault();
                setDragging(false);
                const f = e.dataTransfer.files[0];
                if (f) handleFile(f);
              }}
              onClick={() => document.getElementById("file-input")?.click()}
              className={`border-2 border-dashed rounded-xl p-5 text-center cursor-pointer transition-all ${
                dragging
                  ? "border-[#1d4ed8] bg-blue-50"
                  : file
                    ? "border-emerald-300 bg-emerald-50/60"
                    : "border-slate-200 hover:border-[#1d4ed8]/40 hover:bg-slate-50"
              }`}
            >
              {file ? (
                <div>
                  {preview && (
                    <img
                      src={preview}
                      alt="slide preview"
                      className="mx-auto mb-3 max-h-36 rounded-xl object-cover ring-2 ring-emerald-200"
                    />
                  )}
                  <p className="text-emerald-700 text-xs font-semibold">
                    {file.name}
                  </p>
                  <p className="text-slate-400 text-[11px] mt-0.5">
                    {(file.size / 1024).toFixed(0)} KB
                  </p>
                  <button
                    type="button"
                    onClick={(e) => {
                      e.stopPropagation();
                      setFile(null);
                      setPreview("");
                    }}
                    className="mt-2 text-slate-400 hover:text-red-500 text-[11px] transition-colors"
                  >
                    Change image
                  </button>
                </div>
              ) : (
                <div className="py-4">
                  <Upload className="w-8 h-8 text-slate-300 mx-auto mb-2" />
                  <p className="text-slate-500 text-sm">
                    Drop pathology slide here
                  </p>
                  <p className="text-slate-400 text-xs mt-1">
                    or click · PNG, JPG, TIFF
                  </p>
                </div>
              )}
            </div>
            <input
              id="file-input"
              type="file"
              accept="image/*"
              className="hidden"
              onChange={(e) => {
                const f = e.target.files?.[0];
                if (f) handleFile(f);
                e.target.value = "";
              }}
            />

            <input
              type="text"
              placeholder="Patient HN (e.g. HN-2026-DEMO01)"
              value={patientHn}
              onChange={(e) => setPatientHn(e.target.value)}
              className="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-[#0a1628] placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-[#1d4ed8]/20 focus:border-[#1d4ed8] transition"
            />

            <textarea
              placeholder="Clinical history / findings (optional)…"
              value={clinical}
              onChange={(e) => setClinical(e.target.value)}
              rows={3}
              className="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-[#0a1628] placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-[#1d4ed8]/20 focus:border-[#1d4ed8] resize-none transition"
            />

            <button
              type="submit"
              disabled={!file || isAnalyzing}
              className="w-full bg-[#1d4ed8] hover:bg-blue-700 disabled:bg-slate-100 disabled:text-slate-400 text-white font-semibold py-2.5 rounded-xl transition-colors flex items-center justify-center gap-2 text-sm shadow-sm shadow-blue-200"
            >
              {isAnalyzing ? (
                <>
                  <Loader2 className="w-4 h-4 animate-spin" /> Analyzing…
                </>
              ) : (
                "Run PICHA Analysis"
              )}
            </button>
          </form>
        </div>

        {/* ── Agent Pipeline ── */}
        <div className="xl:col-span-3 bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden flex flex-col min-h-80">
          <div className="px-6 py-4 border-b border-slate-100 flex items-center justify-between shrink-0">
            <div>
              <h2 className="text-[#0a1628] font-bold text-base">
                Explainable AI Pipeline
              </h2>
              <p className="text-slate-400 text-xs mt-0.5">
                PICHA MARS — 7 specialist agents · step-by-step reasoning
              </p>
            </div>
            <div>
              {isAnalyzing && (
                <span className="flex items-center gap-1.5 text-[#1d4ed8] text-xs font-medium bg-blue-50 px-2.5 py-1 rounded-full">
                  <span className="w-1.5 h-1.5 rounded-full bg-[#1d4ed8] animate-pulse" />
                  Running…
                </span>
              )}
              {done && !error && (
                <span className="flex items-center gap-1.5 text-emerald-700 text-xs font-medium bg-emerald-50 px-2.5 py-1 rounded-full">
                  <CheckCircle className="w-3.5 h-3.5" /> Complete
                </span>
              )}
              {error && (
                <span className="flex items-center gap-1.5 text-red-600 text-xs font-medium bg-red-50 px-2.5 py-1 rounded-full">
                  <XCircle className="w-3.5 h-3.5" /> Error
                </span>
              )}
            </div>
          </div>

          <div className="flex-1 flex flex-col p-5">
            {events.length === 0 && !error && (
              <div className="flex-1 flex items-center justify-center min-h-48 text-slate-300">
                {isAnalyzing ? (
                  <div className="text-center">
                    <Loader2 className="w-8 h-8 text-[#1d4ed8]/40 animate-spin mx-auto mb-3" />
                    <p className="text-sm text-slate-500">
                      Initializing agents…
                    </p>
                    <p className="text-xs text-slate-400 mt-1">
                      ConvNeXt pre-screening image
                    </p>
                  </div>
                ) : (
                  <div className="text-center">
                    <div className="w-14 h-14 rounded-2xl bg-slate-50 border-2 border-dashed border-slate-200 flex items-center justify-center mx-auto mb-3">
                      <Microscope className="w-6 h-6 text-slate-300" />
                    </div>
                    <p className="text-sm text-slate-400">
                      Submit a slide to begin analysis
                    </p>
                  </div>
                )}
              </div>
            )}

            {events.length > 0 && (
              <div
                className="flex-1 overflow-y-auto space-y-2 pr-1"
                style={{
                  maxHeight: finalReport ? "22rem" : "36rem",
                  scrollbarWidth: "thin",
                }}
              >
                {events.filter(isDisplayableEvent).map((ev, i) => (
                  <AgentStepCard
                    key={i}
                    event={ev}
                    stepNumber={AGENT_STEP_ORDER[ev.agent] ?? i + 1}
                  />
                ))}
                <div ref={eventsEndRef} />
              </div>
            )}

            {error && (
              <div className="mt-3 p-3 bg-red-50 border border-red-100 rounded-xl shrink-0">
                <p className="text-red-600 text-xs">{error}</p>
              </div>
            )}

            {finalReport && (
              <MedicalReportCard
                report={finalReport}
                patientHn={currentHnRef.current}
                fileName={currentFileRef.current?.name ?? ""}
              />
            )}
          </div>
        </div>
      </div>

      {/* ── Audit Log ──────────────────────────────────────────────────── */}
      <div className="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
        <div className="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
          <div>
            <h2 className="text-[#0a1628] font-bold text-base">
              Recent Activity
            </h2>
            <p className="text-slate-400 text-xs mt-0.5">
              Audit log of all analyses
            </p>
          </div>
          <button
            onClick={loadLogs}
            disabled={logsLoading}
            className="flex items-center gap-1.5 text-slate-400 hover:text-[#1d4ed8] text-xs font-medium transition-colors disabled:opacity-50"
          >
            <RefreshCw
              className={`w-3.5 h-3.5 ${logsLoading ? "animate-spin" : ""}`}
            />
            Refresh
          </button>
        </div>

        {logs.length === 0 ? (
          <div className="flex flex-col items-center justify-center py-14 gap-3">
            <div className="w-12 h-12 rounded-2xl bg-slate-50 border-2 border-dashed border-slate-200 flex items-center justify-center">
              <FileText className="w-5 h-5 text-slate-300" />
            </div>
            <p className="text-slate-400 text-sm">No activity recorded yet</p>
          </div>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-sm min-w-[560px]">
              <thead>
                <tr className="text-left bg-slate-50 text-slate-400 text-[11px] border-b border-slate-100">
                  <th className="py-3 px-4 font-bold uppercase tracking-widest whitespace-nowrap">
                    Time
                  </th>
                  <th className="py-3 px-4 font-bold uppercase tracking-widest">
                    User
                  </th>
                  <th className="py-3 px-4 font-bold uppercase tracking-widest">
                    Action
                  </th>
                  <th className="py-3 px-4 font-bold uppercase tracking-widest whitespace-nowrap">
                    Patient HN
                  </th>
                  <th className="py-3 px-4 font-bold uppercase tracking-widest">
                    Conf.
                  </th>
                  <th className="py-3 px-4 font-bold uppercase tracking-widest">
                    Status
                  </th>
                </tr>
              </thead>
              <tbody>
                {logs.map((log) => (
                  <tr
                    key={log.id}
                    className="border-b border-slate-50 hover:bg-blue-50/40 transition-colors"
                  >
                    <td className="py-3 px-4 text-slate-400 text-xs whitespace-nowrap">
                      {new Date(log.created_at).toLocaleString("th-TH", {
                        dateStyle: "short",
                        timeStyle: "short",
                        hour12: false,
                      })}
                    </td>
                    <td className="py-3 px-4 text-[#0a1628] text-xs font-medium">
                      {log.user_name}
                    </td>
                    <td className="py-3 px-4 text-slate-500 text-xs max-w-[220px] truncate">
                      {log.action}
                    </td>
                    <td className="py-3 px-4 text-slate-500 text-xs font-mono">
                      {log.patient_hn ?? "—"}
                    </td>
                    <td className="py-3 px-4 text-slate-500 text-xs">
                      {log.confidence
                        ? `${Number(log.confidence).toFixed(0)}%`
                        : "—"}
                    </td>
                    <td className="py-3 px-4">
                      <span
                        className={`px-2 py-0.5 rounded-full text-[11px] font-semibold ${
                          log.status === "ok"
                            ? "bg-emerald-50 text-emerald-700 border border-emerald-100"
                            : "bg-red-50 text-red-600 border border-red-100"
                        }`}
                      >
                        {log.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  );
}
